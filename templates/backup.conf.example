# ════════════════════════════════════════════════════════════════
# Universal Linux Backup & Disaster Recovery Framework
# Configuration File — backup.conf
# ════════════════════════════════════════════════════════════════
#
# This file is the single source of truth for THIS server's backup
# behavior. Generated by the setup wizard; safe to hand-edit afterward.
#
# FORMAT RULE (enforced by core/config-loader.sh before this file is
# ever sourced as code): every non-comment, non-blank line must match
#     ^[A-Z0-9_]+=.*$
# Anything else causes the loader to refuse to load this file. This
# file is sourced directly by bash, so validating its shape first is
# what prevents a malformed or tampered config from executing as
# arbitrary code under root.
#
# Do NOT put real secrets (passwords, access keys, tokens) in this
# file. See the SECRETS section below — they live in a separate,
# tightly-permissioned file instead, so this file can be safely
# viewed, copied as a template, or shared for support.
#
# ──────────────────────────────────────────────────────────────────
# SCHEMA VERSION
# ──────────────────────────────────────────────────────────────────
# Identifies which version of this schema the file follows. Checked
# on every run; the framework warns (never silently misbehaves) if
# this predates the installed framework version, since fields get
# added or renamed across releases.
CONFIG_VERSION=1

# ──────────────────────────────────────────────────────────────────
# SERVER IDENTITY
# ──────────────────────────────────────────────────────────────────
# Friendly, human-chosen name for this server. Used in manifest
# headers, restic snapshot tags, backup reports, and notifications.
# Does not need to match the actual hostname.
SERVER_NAME="openclaw"

# ──────────────────────────────────────────────────────────────────
# BACKUP DESTINATION
# ──────────────────────────────────────────────────────────────────
# Selects which destinations/<value>.sh adapter handles this backup.
# Set by the wizard; safe to change by hand, but re-run the
# connectivity test afterward (--test-destination).
#
# Supported values: local | sftp | s3 | rclone
DEST_TYPE="local"

# --- local: repository lives on this server's own disk ---
# Used only when DEST_TYPE=local.
DEST_LOCAL_PATH="/var/backups/backup-framework/repo"

# --- sftp: another Linux server, or a PC reached over SSH ---
# Used only when DEST_TYPE=sftp. HOST_ALIAS must match a Host entry
# in /root/.ssh/config (the wizard creates this for you, including
# key generation and the remote-side authorized_keys setup).
DEST_SFTP_HOST_ALIAS="himesh-backup"
DEST_SFTP_REPO_PATH="restic-repo"

# --- s3: any S3-compatible object storage ---
# Used only when DEST_TYPE=s3. Works for AWS S3, DigitalOcean Spaces,
# Backblaze B2, Wasabi, MinIO, etc. — just change DEST_S3_ENDPOINT.
# Credentials are NOT stored here; see SECRETS_FILE below.
DEST_S3_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DEST_S3_BUCKET="my-backup-bucket"

# --- rclone: Google Drive, OneDrive, Dropbox, Azure Blob, etc. ---
# Used only when DEST_TYPE=rclone. REMOTE_NAME must already exist in
# `rclone config` — the wizard walks you through that interactively
# since OAuth-based providers need a human in the loop.
DEST_RCLONE_REMOTE_NAME="gdrive"
DEST_RCLONE_REPO_PATH="openclaw-backups"

# ──────────────────────────────────────────────────────────────────
# SECRETS
# ──────────────────────────────────────────────────────────────────
# Path to a separate file holding actual credentials: the restic
# repository password, and S3 access keys if DEST_TYPE=s3. chmod 600,
# root-owned, generated by the wizard. Kept out of this file on
# purpose — this file is meant to be safely viewable/shareable;
# secrets.env is not.
SECRETS_FILE="/etc/backup-framework/secrets.env"

# ──────────────────────────────────────────────────────────────────
# RETENTION POLICY
# ──────────────────────────────────────────────────────────────────
RETENTION_ENABLED=true

# Number of most recent daily snapshots to keep. 0 = unlimited
# (storage grows forever — not recommended).
RETENTION_DAILY=15

# Reserved for future use. Leave at 0 until weekly/monthly rollup
# retention ships; setting these now will be ignored, not erroring,
# so upgrading the framework later won't require editing this file.
RETENTION_WEEKLY=0
RETENTION_MONTHLY=0

# ──────────────────────────────────────────────────────────────────
# BACKUP EXECUTION & VERIFICATION
# ──────────────────────────────────────────────────────────────────
# auto | max | off — passed straight through to `restic backup
# --compression`. auto is restic's own default; max trades CPU for
# smaller storage; off is for data that's already compressed (e.g.
# media files) where compression would just waste time.
BACKUP_COMPRESSION="auto"

# Runs a cheap, fast `restic check` (structure/index only, no data
# re-read) after every backup. Safe to leave on always.
VERIFY_BACKUP=true

# Runs the expensive `restic check --read-data`, which re-downloads
# and verifies every byte from the destination, on this cadence
# instead of every run — re-reading the whole repository nightly over
# a slow link is its own disaster. 0 disables the deep check entirely.
VERIFY_DATA_INTERVAL_DAYS=7

# How long (seconds) a backup should wait and quietly retry if it
# finds an existing repository lock, via restic's own --retry-lock,
# before giving up. This waits it out rather than force-removing the
# lock, which could corrupt things if another run is genuinely still
# in progress.
LOCK_RETRY_SECONDS=600

# ──────────────────────────────────────────────────────────────────
# DATABASE BACKUP MODE
# ──────────────────────────────────────────────────────────────────
# auto     = detect running PostgreSQL/MySQL/MariaDB on every single
#            run and dump whichever are currently online. Self-
#            healing: an engine installed months from now is picked
#            up automatically, no config edit required. Recommended.
# manual   = dump only the engines explicitly listed below,
#            regardless of what's actually detected.
# disabled = never run a logical dump; rely solely on the filesystem
#            backup. Valid choice for servers with no real database,
#            or where dump time/cost isn't justified.
DB_MODE="auto"

# Only read when DB_MODE=manual. Comma-separated: postgresql, mysql,
# mariadb.
DB_MANUAL_ENGINES="postgresql"

# Relevant for PostgreSQL under auto or manual mode. Comma-separated
# list of cluster ports to skip even if found running — for known,
# intentionally-unused clusters (e.g. a stale leftover version you
# don't want dumped every night).
DB_POSTGRES_SKIP_PORTS=""

# ──────────────────────────────────────────────────────────────────
# MANIFEST
# ──────────────────────────────────────────────────────────────────
MANIFEST_ENABLED=true

# core     = packages, services, ports, mounts, cron — a few seconds,
#            always safe to run.
# extended = adds slower/larger checks: full package version list,
#            per-directory file-count/size fingerprints, firewall
#            rules, SSL certificate inventory, SSH/sudo config. A bit
#            slower; default for v1 since restore-validation accuracy
#            matters more than the extra few seconds it costs.
MANIFEST_DEPTH="extended"

# ──────────────────────────────────────────────────────────────────
# PATHS & EXCLUDES
# ──────────────────────────────────────────────────────────────────
# Root path to back up. Almost always "/". Changing this is rare,
# mainly useful for testing.
BACKUP_SOURCE="/"

# Path to the exclude file (restic --exclude-file). The framework
# ships sane defaults (virtual filesystems, its own repo/cache dirs,
# Docker's regenerable overlay2 internals). Add server-specific
# excludes inside that file, one path per line — not in this one.
EXCLUDE_FILE="/etc/backup-framework/excludes.txt"

# ──────────────────────────────────────────────────────────────────
# SCHEDULE
# ──────────────────────────────────────────────────────────────────
# 24-hour local time the daily systemd timer targets.
SCHEDULE_TIME="02:00"

# Random extra delay, in minutes, added on top of SCHEDULE_TIME, so
# many client servers sharing one destination don't all start at the
# exact same instant and contend for bandwidth.
SCHEDULE_JITTER_MINUTES=30

# Set true to make a scheduled run exit immediately and log a
# skip-notice instead of backing up — for planned maintenance windows,
# without touching the systemd timer itself.
MAINTENANCE_MODE=false

# ──────────────────────────────────────────────────────────────────
# NOTIFICATIONS
# ──────────────────────────────────────────────────────────────────
# none | webhook | email — matches an adapter under notify/.
NOTIFY_METHOD="none"
NOTIFY_ON_SUCCESS=false
NOTIFY_ON_FAILURE=true

# Used only when NOTIFY_METHOD=webhook.
NOTIFY_WEBHOOK_URL=""

# Used only when NOTIFY_METHOD=email.
NOTIFY_EMAIL_TO=""

# ──────────────────────────────────────────────────────────────────
# RESTORE (reserved — Phase 2)
# ──────────────────────────────────────────────────────────────────
# Inert for now. Reserved so Phase 2 doesn't require a breaking
# schema change to introduce restore behavior.
RESTORE_DEFAULT_TARGET=""
RESTORE_VALIDATION_ENABLED=true

# ──────────────────────────────────────────────────────────────────
# ADVANCED / INTERNAL PATHS
# ──────────────────────────────────────────────────────────────────
# Sensible framework defaults. Exposed here — rather than hardcoded
# in scripts — purely so an advanced user CAN override them without
# touching any code. Most installs should never need to change these.
MANIFEST_DIR="/var/backups/backup-framework/manifest"
DUMP_DIR="/var/backups/backup-framework/dumps"
LOG_FILE="/var/log/backup-framework/backup.log"
LOCK_FILE="/run/backup-framework.lock"

